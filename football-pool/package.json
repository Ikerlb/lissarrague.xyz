{
  "name": "football-pool",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute football-pool-db --local --file=src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute football-pool-db --remote --file=src/db/schema.sql",
    "db:seed:local": "wrangler d1 execute football-pool-db --local --file=src/db/seed.sql"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "wrangler": "^3.57.0"
  }
}
